# Dependencies
node_modules/

# Build output
# Note: dist/ is committed because Claude Code plugins need pre-built files.
# dist/
# Source maps are disabled in tsconfig; block them so stray maps can never be
# committed even if a contributor builds with a different config.
dist/**/*.map
*.tsbuildinfo

# Logs
*.log
npm-debug.log*

# Environment
.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Testing
coverage/

# Config (user-specific)
.privacy-guard.json

# Local Claude Code settings
.claude/
