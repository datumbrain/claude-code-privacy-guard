{
  "name": "claude-code-privacy-guard",
  "version": "0.2.8",
  "type": "module",
  "description": "Privacy guard plugin for Claude Code - prevents PII and secrets from leaking into AI prompts",
  "bin": {
    "claude-code-privacy-guard": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "data",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build"
  },
  "keywords": [
    "claude",
    "privacy",
    "security",
    "pii",
    "secrets",
    "ai-safety"
  ],
  "author": "Datum Brain",
  "license": "MIT",
  "dependencies": {
    "js-yaml": "^4.1.0",
    "safe-regex2": "^5.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
